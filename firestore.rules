rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for all collections
    match /companies/{companyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /insights/{insightId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /market_stats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /signals/{signalId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /signal_history/{historyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /import_batches/{batchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}